# Gemini API キー
# 取得先: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_api_key_here

# -----------------------------------------------------------
# 使い分け方
#
# ローカル開発 (npm run dev) の場合:
#   このファイルを .env.local としてコピーして使う
#   $ cp .env.example .env.local
#
# Docker (docker compose up) の場合:
#   このファイルを .env としてコピーして使う
#   $ cp .env.example .env
#
# どちらのファイルも .gitignore により Git 管理外です。
# -----------------------------------------------------------
